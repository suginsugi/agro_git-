{
  "name": "agrovision-e2e-tests",
  "version": "1.0.0",
  "description": "Selenium E2E Automation Framework for AgroVision",
  "main": "index.js",
  "scripts": {
    "test": "mocha --timeout 60000 --reporter mochawesome --reporter-options reportDir=./reports,reportFilename=E2E_Report,html=true,json=true,overwrite=true tests/setup.js tests/**/*.spec.js",
    "test:headed": "set HEADLESS=false&& mocha --timeout 60000 --reporter mochawesome --reporter-options reportDir=./reports,reportFilename=E2E_Report,html=true,json=true,overwrite=true tests/setup.js tests/**/*.spec.js",
    "test:parallel": "mocha --timeout 60000 --reporter mochawesome --reporter-options reportDir=./reports,reportFilename=E2E_Report,html=true,json=true,overwrite=true tests/setup.js tests/**/*.spec.js --parallel"
  },
  "keywords": [
    "selenium",
    "e2e",
    "testing",
    "automation",
    "react"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "chai": "^4.3.10",
    "dotenv": "^16.4.5",
    "exceljs": "^4.4.0",
    "mocha": "^10.4.0",
    "mochawesome": "^7.1.3",
    "selenium-webdriver": "^4.21.0",
    "winston": "^3.13.0"
  }
}
