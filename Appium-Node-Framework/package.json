{
  "name": "enterprise-appium-framework",
  "version": "1.0.0",
  "description": "Enterprise Appium E2E Automation Framework for Android Application",
  "main": "index.js",
  "scripts": {
    "test": "mocha tests/**/*.spec.js --timeout 120000 --reporter mochawesome --reporter-options reportDir=reports,reportFilename=Mochawesome_Report",
