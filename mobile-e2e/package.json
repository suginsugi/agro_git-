{
  "name": "agrovision-mobile-e2e",
  "version": "1.0.0",
  "description": "Enterprise Appium E2E Automation Framework for Android Application",
  "main": "index.js",
  "scripts": {
    "test": "wdio run config/wdio.conf.js",
    "test:local": "cross-env APP_ENV=local wdio run config/wdio.conf.js",
    "test:ci": "cross-env APP_ENV=ci wdio run config/wdio.conf.js",
    "report": "npx mochawesome-merge reports/json/*.json > reports/mochawesome.json && npx marge reports/mochawesome.json -f report -o reports/html"
  },
  "keywords": [
    "appium",
    "webdriverio",
    "android",
    "automation",
    "e2e",
    "mocha"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "chai": "^4.3.7",
    "cross-env": "^7.0.3",
    "exceljs": "^4.3.0",
    "winston": "^3.10.0",
    "moment": "^2.29.4"
  },
  "devDependencies": {
    "@wdio/appium-service": "^8.14.0",
    "@wdio/cli": "^8.14.0",
    "@wdio/local-runner": "^8.14.0",
    "@wdio/mocha-framework": "^8.14.0",
    "@wdio/spec-reporter": "^8.14.0",
    "appium": "^2.1.3",
    "appium-uiautomator2-driver": "^2.29.4",
    "mochawesome": "^7.1.3",
    "mochawesome-merge": "^4.3.0",
    "mochawesome-report-generator": "^6.2.0"
  }
}
